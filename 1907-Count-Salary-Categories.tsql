1/* Write your T-SQL query statement below */
2select 'Low Salary' as category, count(account_id) as accounts_count  from Accounts where income < 20000
3UNION ALL
4select 'Average Salary' as category, count(account_id) as accounts_count from Accounts where income >= 20000  and income <= 50000
5UNION ALL
6select 'High Salary' as category, count(account_id) as accounts_count from Accounts where income > 50000
