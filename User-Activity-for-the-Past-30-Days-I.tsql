1/* Write your T-SQL query statement below */
2select activity_date as day, count(distinct user_id) as active_users
3from Activity
4where activity_date BETWEEN DATEADD(day, -29, '2019-07-27') AND '2019-07-27' 
5	and activity_type in ('open_session', 'end_session', 'scroll_down', 'send_message')
6group by activity_date